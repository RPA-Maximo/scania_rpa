# Maximo API 认证信息
# 
# 推荐方式：直接更新 config/响应标头.txt 文件
# 从浏览器开发者工具复制 curl 命令粘贴到 响应标头.txt 即可
# 程序会自动解析 Cookie、CSRF Token 等信息
#
# 备用方式：手动填写以下环境变量（当 响应标头.txt 不存在或解析失败时使用）

# Cookie 字符串（完整的 Cookie header 值）
MAXIMO_COOKIE=your_cookie_string_here

# CSRF Token
MAXIMO_CSRF_TOKEN=your_csrf_token_here

# Refresh Token（可选）
MAXIMO_REFRESH_TOKEN=your_refresh_token_here

# MySQL 数据库连接信息
DB_HOST=222.187.11.98
DB_PORT=33060
DB_NAME=bmp153
DB_USER=bmp153
DB_PASSWORD=45bSnyonIhPk3rsTOSLi
